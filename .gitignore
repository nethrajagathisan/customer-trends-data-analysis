# --- Secrets & environment ---
.env
.env.*
!.env.example

# --- Data (raw inputs are not versioned; large/derived artifacts kept out) ---
data/raw/
data/processed/*.parquet
data/processed/*.csv
!data/processed/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# --- Power BI dashboards (keep only the rebuilt dashboard under dashboards/) ---
*.pbix
!dashboards/*.pbix

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/
